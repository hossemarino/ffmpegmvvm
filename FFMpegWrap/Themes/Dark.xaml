<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System.Windows;assembly=PresentationFramework">
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FF111111" />
    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#FF1B1B1B" />
    <SolidColorBrush x:Key="AppElevatedSurfaceBrush" Color="#FF252525" />
    <SolidColorBrush x:Key="AppForegroundBrush" Color="#FFEAEAEA" />
    <SolidColorBrush x:Key="AppMutedForegroundBrush" Color="#FFB3B3B3" />
    <SolidColorBrush x:Key="AppBorderBrush" Color="#FF3A3A3A" />
    <SolidColorBrush x:Key="AppAccentBrush" Color="#FF60A5FA" />
    <SolidColorBrush x:Key="AppPreviewBrush" Color="#FF000000" />
    <SolidColorBrush x:Key="AppSelectionBrush" Color="#2260A5FA" />

    <SolidColorBrush x:Key="{x:Static system:SystemColors.WindowBrushKey}" Color="#FF1B1B1B" />
    <SolidColorBrush x:Key="{x:Static system:SystemColors.ControlBrushKey}" Color="#FF252525" />
    <SolidColorBrush x:Key="{x:Static system:SystemColors.ControlLightBrushKey}" Color="#FF2F2F2F" />
    <SolidColorBrush x:Key="{x:Static system:SystemColors.ControlLightLightBrushKey}" Color="#FF3A3A3A" />
    <SolidColorBrush x:Key="{x:Static system:SystemColors.ControlDarkBrushKey}" Color="#FF3A3A3A" />
    <SolidColorBrush x:Key="{x:Static system:SystemColors.ControlDarkDarkBrushKey}" Color="#FF111111" />
    <SolidColorBrush x:Key="{x:Static system:SystemColors.ControlTextBrushKey}" Color="#FFEAEAEA" />
    <SolidColorBrush x:Key="{x:Static system:SystemColors.WindowTextBrushKey}" Color="#FFEAEAEA" />
    <SolidColorBrush x:Key="{x:Static system:SystemColors.GrayTextBrushKey}" Color="#FFB3B3B3" />
    <SolidColorBrush x:Key="{x:Static system:SystemColors.HighlightBrushKey}" Color="#2260A5FA" />
    <SolidColorBrush x:Key="{x:Static system:SystemColors.HighlightTextBrushKey}" Color="#FFEAEAEA" />
    <SolidColorBrush x:Key="{x:Static system:SystemColors.InactiveSelectionHighlightBrushKey}" Color="#2260A5FA" />
    <SolidColorBrush x:Key="{x:Static system:SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#FFEAEAEA" />
    <SolidColorBrush x:Key="{x:Static system:SystemColors.ActiveBorderBrushKey}" Color="#FF3A3A3A" />
    <SolidColorBrush x:Key="{x:Static system:SystemColors.InactiveBorderBrushKey}" Color="#FF3A3A3A" />
</ResourceDictionary>
